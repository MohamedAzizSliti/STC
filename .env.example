# Supabase – Next.js quickstart: https://supabase.com/docs/guides/getting-started/quickstarts/nextjs
# Get these from your project's Connect dialog: https://supabase.com/dashboard/project/_?showConnect=true&connectTab=frameworks&framework=nextjs
# Or from Settings > API Keys: Publishable key (new) or anon key (legacy).

NEXT_PUBLIC_SUPABASE_URL=<SUBSTITUTE_SUPABASE_URL>
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<SUBSTITUTE_SUPABASE_PUBLISHABLE_KEY>

# Optional: use legacy anon key instead of publishable key (either one works)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Server-only: for creating profiles on signup, admin operations. From Settings > API Keys > Legacy API Keys > service_role
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Authentication redirect (Supabase Dashboard > Authentication > URL Configuration):
# Site URL: http://localhost:3000
# Redirect URLs: http://localhost:3000/auth/callback
